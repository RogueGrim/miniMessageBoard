<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> <%= title %> </title>
</head>
<body>
    <%- include('navbar') %>
    <div>
        <% messages.forEach((message)=>{ %>
            <div>
                <h1> <%= message.user %> </h1>
                <p> <%= message.text %> </p>
                <p> <%= message.added %> </p>
                <a href="/details/<%=message.id%>"> <button>View</button></a>
            </div>
        <% }) %>
    </div>
</body>
</html>