<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> <%= title %> </title>
</head>
<body>
    <%- include('navbar') %>
    <div>
        <% if(messages) { %>
            <% messages.forEach((data)=>{ %>
                <div>
                    <h1> <%= data.name %> </h1>
                    <p> <%= data.message %> </p>
                    <p> <%= data.time %> </p>
                    <a href="/details/<%=data.id%>"> <button>View</button></a>
                </div>
            <% }) %>
        <% }else{ %>
            <p>No Messages to Display</p>
        <% } %>
    </div>
</body>
</html>